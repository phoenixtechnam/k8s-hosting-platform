# Local development environment configuration
# Copy to .env.local and customize for your setup.
# The local.sh script loads this file automatically.

# ─── Network ──────────────────────────────────────────────────────────────────
# Canonical apex for every user-facing URL in dev. Subdomains (admin,
# client, dex, webmail, mail, mail-admin) are derived from this. The
# operator's internal DNS must resolve *.${PLATFORM_BASE_DOMAIN} to the
# cluster node's LAN IP — no /etc/hosts required.
PLATFORM_BASE_DOMAIN=k8s-platform.test

# Hostname this workspace container uses to reach the DinD daemon + k3s
# API. NEVER part of a user-facing URL — all services use subdomains of
# PLATFORM_BASE_DOMAIN. Legacy alias DOCKER_HOST_NAME is still honored.
DIND_INTERNAL_HOST=dind.local

# Docker daemon (comment out for local Docker, or set for remote)
DOCKER_HOST=tcp://dind:2375

# ─── Published Ports (all within 2010-2030) ───────────────────────────────────
# Ingress (NGINX — serves admin + client panels via hostname routing)
PORT_INGRESS_HTTP=2010
PORT_INGRESS_HTTPS=2011

# Platform services
# Backend API is NOT exposed externally — admin/client panels proxy /api/*
# internally via nginx to platform-api.platform.svc.cluster.local:3000.
PORT_DB=2013            # PostgreSQL
PORT_REDIS=2014         # Redis
PORT_DEX=2015           # Dex OIDC provider
PORT_K3S_API=2016       # k3s Kubernetes API
PORT_WEBMAIL=2017       # Roundcube webmail
PORT_OAUTH2_PROXY=2018  # OAuth2 Proxy
PORT_SFTP=2019          # SFTP Gateway

# Mail server (Stalwart)
PORT_MAIL_SMTP=2020       # SMTP
PORT_MAIL_SUBMISSION=2021 # Submission (587)
PORT_MAIL_IMAP=2022       # IMAP
PORT_MAIL_IMAPS=2023      # IMAPS
PORT_MAIL_SMTPS=2024      # SMTPS
PORT_MAIL_POP3=2025       # POP3
PORT_MAIL_POP3S=2026      # POP3S

# ─── Database ─────────────────────────────────────────────────────────────────
DB_NAME=hosting_platform
DB_USER=platform
DB_PASSWORD=CHANGE_ME

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARS

# ─── Encryption key for stored credentials (64 hex chars) ────────────────────
# Generate with: openssl rand -hex 32
OIDC_ENCRYPTION_KEY=CHANGE_ME_64_HEX_CHARS

# ─── Default Admin User (seeded on first run) ────────────────────────────────
ADMIN_EMAIL=admin@k8s-platform.test
ADMIN_PASSWORD=CHANGE_ME
ADMIN_NAME="Platform Admin"

# ─── Docker Compose ───────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=hosting-platform

# ─── Integration mode ─────────────────────────────────────────────────────────
# The recommended setup is wildcard DNS pointing *.${PLATFORM_BASE_DOMAIN}
# at your host (e.g., via dnsmasq, Pi-hole, or your router's DNS server).
# No /etc/hosts entries required.
#
# Access (dev):
#   Admin Panel:  http://admin.k8s-platform.test:2010 (or https on :2011)
#   Client Panel: http://client.k8s-platform.test:2010 (or https on :2011)
#   Dex OIDC:     https://dex.k8s-platform.test:2011/dex
#   Webmail:      https://webmail.k8s-platform.test:2011
#   Mail-admin:   https://mail-admin.k8s-platform.test:2011
#   SMTP/IMAP:    mail.k8s-platform.test (:2020–:2026)

# ─── Fast-dev mode ────────────────────────────────────────────────────────────
# Infrastructure runs in k3s, apps run on host with hot-reload:
#   ./scripts/local.sh dev
#   cd backend && npm run dev
#   cd frontend/admin-panel && npm run dev
#   cd frontend/client-panel && npm run dev
